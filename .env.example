# ------------------------------------------------------------------
# Database (Neon PostgreSQL)
# Create a project at https://neon.tech and copy the connection strings.
# DATABASE_URL uses the pooled connection (pgbouncer) for the app.
# DIRECT_URL uses the direct connection for Prisma migrations.
# ------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-2.aws.neon.tech/mentorship?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-2.aws.neon.tech/mentorship?sslmode=require"

# ------------------------------------------------------------------
# Auth.js (NextAuth)
# Generate a secret with: openssl rand -base64 32
# ------------------------------------------------------------------
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_URL="https://mentorship-management-system-mod.vercel.app/"
AUTH_TRUST_HOST="true"

# ------------------------------------------------------------------
# Gmail SMTP
# Use a Google account with 2FA enabled and create an App Password:
# https://myaccount.google.com/apppasswords
# ------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="mentymentors@gmail.com"
SMTP_PASSWORD="sbof quek opwf awzo"
EMAIL_FROM="Menty <mentymentors@gmail.com>"

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://mentorship-management-system-mod.vercel.app/"
NEXT_PUBLIC_APP_NAME="Menty"

# Secret used to protect Vercel Cron endpoints (openssl rand -hex 24)
CRON_SECRET="replace-with-a-random-secret"

# Seed script credentials for the initial admin account
SEED_ADMIN_EMAIL="admin@engineering.edu"
SEED_ADMIN_PASSWORD="ChangeMe123!"
