{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "crons": [
    {
      "path": "/api/cron/weekly-reminders",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/meeting-reminders",
      "schedule": "0 7 * * *"
    }
  ]
}
